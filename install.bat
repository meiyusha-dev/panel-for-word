@echo off
:: Word Panel アドイン インストーラー（単体版）
:: このファイルをダブルクリックして管理者として実行してください

:: 管理者権限チェック・昇格
net session >nul 2>&1
if %errorlevel% neq 0 (
    echo 管理者権限で再起動しています...
    powershell -Command "Start-Process -FilePath '%~f0' -Verb RunAs"
    exit /b
)

:: PS1 スクリプトを一時ファイルに展開して実行
set "PS1=%TEMP%\word-panel-install.ps1"

powershell -ExecutionPolicy Bypass -Command ^
  "$b64 = ''; [System.IO.File]::WriteAllBytes('%PS1%', [Convert]::FromBase64String($b64))"

if %errorlevel% neq 0 (
    echo.
    echo [ERROR] スクリプトの展開に失敗しました。
    pause
    exit /b 1
)

powershell -ExecutionPolicy Bypass -File "%PS1%"
del "%PS1%" >nul 2>&1
